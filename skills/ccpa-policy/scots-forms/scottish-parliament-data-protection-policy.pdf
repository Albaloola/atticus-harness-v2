<form action="/api/sitecore/SiteAlert/AcceptCookies?alertItemId=05589ac9-fd6f-4f67-b9fa-749cef670380" data-ajax="true" data-ajax-method="GET" data-ajax-mode="replace-with" data-ajax-success="onAjaxComplete" data-ajax-update="#main-message-banner" method="post">        <div id="main-message-banner">

            <!-- Site Header -->
            <div class="announcement headerAnnouncement setLightBlue " id="05589ac9-fd6f-4f67-b9fa-749cef670380 ">

                <div class="basic-content-half">

                    <div class="final-panel final-panel--larger">

                        <h1 class="h3">
                            Parliament dissolved ahead of election
                        </h1>

                        <p>The Scottish Parliament is now dissolved ahead of the election on Thursday 7 May 2026. </p>
<p>During <a href="https://www.parliament.scot/glossary#az_dissolution">dissolution</a>, there are no MSPs and no parliamentary business can take place.</p>
<p><a href="https://www.parliament.scot/msps/elections/election-2026" class="link-icon--info">For more information, please visit Election 2026</a></p>

                        <div class="content-block__end-icon">

                            <button class="new-button new-button--simple js--remove" onClick="hideBanner()">

                                <svg class="svg-icon" aria-hidden="true">
                                    <use xlink:href="#svg--close"></use>
                                </svg>

                            </button>

                        </div>

                    </div>

                </div>

            </div>

        </div>
</form>

