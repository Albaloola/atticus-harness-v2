<!DOCTYPE html>
<html  lang="en" dir="ltr" prefix="content: http://purl.org/rss/1.0/modules/content/  dc: http://purl.org/dc/terms/  foaf: http://xmlns.com/foaf/0.1/  og: http://ogp.me/ns#  rdfs: http://www.w3.org/2000/01/rdf-schema#  schema: http://schema.org/  sioc: http://rdfs.org/sioc/ns#  sioct: http://rdfs.org/sioc/types#  skos: http://www.w3.org/2004/02/skos/core#  xsd: http://www.w3.org/2001/XMLSchema# ">
  <head>
    <meta charset="utf-8" />
<script type="text/javascript">(function() {
  console.log('[ACAS Debug] Inline script executed at ' + new Date().toISOString());
  window.acasDefineGlyphiconFunctions = function() {
    console.log('[ACAS Debug] Defining glyphicon functions from inline script');
    // Ensure Drupal and Drupal.Ajax exist
    window.Drupal = window.Drupal || {};
    window.Drupal.Ajax = window.Drupal.Ajax || function () {};
    window.Drupal.Ajax.prototype = window.Drupal.Ajax.prototype || {};

    // Define glyphiconStart if it doesn't exist
    window.Drupal.Ajax.prototype.glyphiconStart = function (element) {
      console.log('[ACAS Debug] glyphiconStart called from inline script');
      try {
        if (element &amp;&amp; window.jQuery) {
          window.jQuery(element).addClass('is-autocompleting');
          window.jQuery(element).siblings('.glyphicon').addClass('glyphicon-spin');
          console.log('[ACAS Debug] Added autocomplete throbber classes');
        }
      } catch (e) {
        console.warn('[ACAS Debug] Error in glyphiconStart:', e);
      }
      return this;
    };

    // Define glyphiconStop if it doesn't exist
    window.Drupal.Ajax.prototype.glyphiconStop = function (element) {
      console.log('[ACAS Debug] glyphiconStop called from inline script');
      try {
        if (element &amp;&amp; window.jQuery) {
          window.jQuery(element).removeClass('is-autocompleting');
          window.jQuery(element).siblings('.glyphicon').removeClass('glyphicon-spin');
          console.log('[ACAS Debug] Removed autocomplete throbber classes');
        }
      } catch (e) {
        console.warn('[ACAS Debug] Error in glyphiconStop:', e);
      }
      return this;
    };
    console.log('[ACAS Debug] Successfully defined glyphicon functions from inline script');
  };

  // Execute immediately
  window.acasDefineGlyphiconFunctions();

  // Set up a periodic check to ensure the functions exist
  var checkInterval = setInterval(function() {
    if (window.Drupal &amp;&amp; window.Drupal.Ajax &amp;&amp; window.Drupal.Ajax.prototype) {
      if (typeof window.Drupal.Ajax.prototype.glyphiconStart !== 'function' ||
          typeof window.Drupal.Ajax.prototype.glyphiconStop !== 'function') {
        console.log('[ACAS Debug] Redefining missing glyphicon functions in inline script');
        window.acasDefineGlyphiconFunctions();
      }
    }
  }, 50); // Check every 50ms

  // Stop checking after 5 seconds
  setTimeout(function() {
    clearInterval(checkInterval);
    console.log('[ACAS Debug] Stopped periodic glyphicon function checks in inline script');
  }, 5000);

  // Also patch jQuery UI autocomplete if it's already loaded
  function patchjQueryUIAutocomplete() {
    if (window.jQuery &amp;&amp; window.jQuery.ui &amp;&amp; window.jQuery.ui.autocomplete) {
      console.log('[ACAS Debug] jQuery UI autocomplete found in inline script, patching methods');
      // Store the original methods
      var originalSearch = window.jQuery.ui.autocomplete.prototype._search;
      var originalResponse = window.jQuery.ui.autocomplete.prototype._response;

      // Override the _search method with a simple implementation
      window.jQuery.ui.autocomplete.prototype._search = function(value) {
        console.log('[ACAS Debug] Patched _search method called from inline script');
        // Make sure the functions exist
        window.acasDefineGlyphiconFunctions();

        // Call glyphiconStart directly
        try {
          var element = this.element[0];
          if (element) {
            window.Drupal.Ajax.prototype.glyphiconStart(element);
          }
        } catch (e) {
          console.warn('[ACAS Debug] Error calling glyphiconStart from inline script:', e);
        }

        // Call original method and return its result
        return originalSearch.apply(this, arguments);
      };

      // Override the _response method with a simple implementation
      window.jQuery.ui.autocomplete.prototype._response = function(items) {
        console.log('[ACAS Debug] Patched _response method called from inline script');
        // Make sure the functions exist
        window.acasDefineGlyphiconFunctions();

        // Call glyphiconStop directly
        try {
          var element = this.element[0];
          if (element) {
            window.Drupal.Ajax.prototype.glyphiconStop(element);
          }
        } catch (e) {
          console.warn('[ACAS Debug] Error calling glyphiconStop from inline script:', e);
        }

        // Call original method and return its result
        return originalResponse.apply(this, arguments);
      };

      console.log('[ACAS Debug] Successfully patched jQuery UI autocomplete methods from inline script');
      return true;
    }
    return false;
  }

  // Try to patch immediately
  var patchSuccess = patchjQueryUIAutocomplete();

  // If not successful, set up a periodic check
  if (!patchSuccess) {
    var patchInterval = setInterval(function() {
      if (patchjQueryUIAutocomplete()) {
        clearInterval(patchInterval);
        console.log('[ACAS Debug] Successfully patched jQuery UI autocomplete after waiting');
      }
    }, 50); // Check every 50ms

    // Stop checking after 10 seconds
    setTimeout(function() {
      clearInterval(patchInterval);
      console.log('[ACAS Debug] Stopped checking for jQuery UI autocomplete');
    }, 10000);
  }
})();</script>
<script type="text/javascript">(function() {
    'use strict';
    
    function fixCaretAccessibility() {
      console.log('[Caret Fix] Running inline caret fix');
      
      var carets = document.querySelectorAll('.dropdown-toggle .caret');
      console.log('[Caret Fix] Found carets:', carets.length);
      
      carets.forEach(function(caret) {
        // Skip if already processed
        if (caret.hasAttribute('data-caret-fixed')) {
          return;
        }
        
        console.log('[Caret Fix] Processing caret:', caret);
        
        // Make caret focusable
        caret.setAttribute('tabindex', '0');
        caret.setAttribute('role', 'button');
        caret.setAttribute('aria-label', 'Toggle menu');
        caret.setAttribute('data-caret-fixed', 'true');
        
        // Handle keyboard events
        caret.addEventListener('keydown', function(e) {
          if (e.keyCode === 13 || e.keyCode === 32) { // Enter or Space
            e.preventDefault();
            e.stopPropagation();
            
            var dropdownToggle = caret.closest('.dropdown-toggle');
            if (dropdownToggle) {
              // Use Bootstrap's dropdown toggle method if available
              if (window.jQuery &amp;&amp; window.jQuery.fn.dropdown) {
                window.jQuery(dropdownToggle).dropdown('toggle');
                
                // Also trigger mobile-open class for mobile compatibility
                var parentLi = dropdownToggle.closest('li');
                if (parentLi) {
                  if (parentLi.classList.contains('mobile-open')) {
                    parentLi.classList.remove('mobile-open');
                  } else {
                    parentLi.classList.add('mobile-open');
                  }
                }
              } else {
                // Fallback: manually toggle the dropdown menu
                var dropdownMenu = dropdownToggle.nextElementSibling;
                if (dropdownMenu &amp;&amp; dropdownMenu.classList.contains('dropdown-menu')) {
                  var isExpanded = dropdownToggle.getAttribute('aria-expanded') === 'true';
                  var parentLi = dropdownToggle.closest('li');
                  
                  if (isExpanded) {
                    dropdownToggle.setAttribute('aria-expanded', 'false');
                    dropdownMenu.style.display = 'none';
                    if (parentLi) {
                      parentLi.classList.remove('mobile-open');
                    }
                  } else {
                    dropdownToggle.setAttribute('aria-expanded', 'true');
                    dropdownMenu.style.display = 'block';
                    if (parentLi) {
                      parentLi.classList.add('mobile-open');
                    }
                  }
                }
              }
            }
          }
        });
        
        // Handle click events
        caret.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          
          var dropdownToggle = caret.closest('.dropdown-toggle');
          if (dropdownToggle) {
            // Use Bootstrap's dropdown toggle method if available
            if (window.jQuery &amp;&amp; window.jQuery.fn.dropdown) {
              window.jQuery(dropdownToggle).dropdown('toggle');
              
              // Also trigger mobile-open class for mobile compatibility
              var parentLi = dropdownToggle.closest('li');
              if (parentLi) {
                if (parentLi.classList.contains('mobile-open')) {
                  parentLi.classList.remove('mobile-open');
                } else {
                  parentLi.classList.add('mobile-open');
                }
              }
            } else {
              // Fallback: manually toggle the dropdown menu
              var dropdownMenu = dropdownToggle.nextElementSibling;
              if (dropdownMenu &amp;&amp; dropdownMenu.classList.contains('dropdown-menu')) {
                var isExpanded = dropdownToggle.getAttribute('aria-expanded') === 'true';
                var parentLi = dropdownToggle.closest('li');
                
                if (isExpanded) {
                  dropdownToggle.setAttribute('aria-expanded', 'false');
                  dropdownMenu.style.display = 'none';
                  if (parentLi) {
                    parentLi.classList.remove('mobile-open');
                  }
                } else {
                  dropdownToggle.setAttribute('aria-expanded', 'true');
                  dropdownMenu.style.display = 'block';
                  if (parentLi) {
                    parentLi.classList.add('mobile-open');
                  }
                }
              }
            }
          }
        });
        
        // Add visual focus indicator
        caret.addEventListener('focus', function() {
          caret.classList.add('caret-focus');
        });
        
        caret.addEventListener('blur', function() {
          caret.classList.remove('caret-focus');
        });
      });
    }
    
    // Run immediately
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', fixCaretAccessibility);
    } else {
      fixCaretAccessibility();
    }
    
    // Also run after a short delay to catch dynamically loaded content
    setTimeout(fixCaretAccessibility, 1000);
    
  })();</script>
