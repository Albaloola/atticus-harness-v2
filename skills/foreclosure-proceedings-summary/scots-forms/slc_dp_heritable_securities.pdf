acity: 0; pointer-events: none; position: relative; width: 100vw; left: 0;}.mobile-nav-holder.open {opacity: 1; pointer-events: auto; padding: 30px 0;}.mobile-nav-holder > .container {display: flex; flex-direction: column; gap: 24px;}.mobile-nav-holder ul {display: flex; flex-direction: column; list-style: none; padding: 0; margin: 0; white-space: nowrap;}.mobile-nav-holder li.menu-open svg {transform: rotate(180deg);}.mobile-nav-holder a.parent {display: flex; gap: 12px; align-items: center;}.mobile-nav-holder a.parent path {fill: var(--white);}.mobile-nav-holder ul a {font-size: 19px; line-height: 32px; color: var(--white); text-decoration: none; display: flex; align-items: center; justify-content: space-between; padding: 8px 16px;}.mobile-nav-holder ul li:hover > a, .mobile-nav-holder ul a:active, .mobile-nav-holder ul a:focus-visible, .mobile-nav-holder ul li:focus-within > a.parent {background-color: var(--blue-400);}.mobile-nav-holder .child-list {display: none; margin-left: 16px; transition: height 0s;}.mobile-nav-holder .child-list a {font-size: 16px; line-height: 24px; padding: 12px 16px;}.mobile-nav-holder .child-list li:hover > a, .mobile-nav-holder .child-list a:active, .mobile-nav-holder .child-list a:focus-visible {background-color: var(--white); color: var(--blue-500);}.mobile-nav-holder .main-menu > li + li::before {content: ""; display: block; height: 1px; margin: 8px 0; background: var(--blue-400); pointer-events: none;}.hero > .container {display: flex; flex-direction: column; gap: 12px;}.hero, .paras {padding-top: 32px; padding-bottom: 32px;}.paras > div {display: flex; flex-direction: column; gap: 32px;}.txt {display: flex; flex-direction: column;}.content {display: flex; flex-direction: column; gap: 20px; padding-top: 32px; padding-bottom: 32px;}.content:has(+ .paras, ~ .related-publications), .paras:has(+ .related-publications) {padding-bottom: 16px;}.content + .paras, .content ~ .related-publications, .paras + .related-publications {padding-t