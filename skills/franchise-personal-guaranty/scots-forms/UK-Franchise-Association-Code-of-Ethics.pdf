 var $elTabs = $( '.elementor-tab-title.elementor-tab-desktop-title, .e-n-tab-title' );
 var maybeHideElement = function( $el, $content ) {
 // Tab has content if it has any Jet listing grid items (items may have no visible text – overlay links, images only).
 if ( $content.find( '.jet-listing-grid__item' ).length ) {
 return false;
 }
