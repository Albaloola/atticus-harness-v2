 if ( $content.find( '.jet-listing-grid' ).length && ! $content.find( '.jet-listing-not-found' ).length ) {
 return false;
 }
 var text = $content.text();
 text = text.replace( /\t|\s/g, '' );
 text = text.replace( /\r?\n|\r/g, '' );
 if ( ! text ) {
 $el.css( 'display', 'none' );
